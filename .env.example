# Repository and registry
PROJECT_NAME=city-intersection-project
ENV=prod
REGISTRY_PREFIX=registry.example.com/city-intersection
IMAGE_PULL_SECRET=registry-credentials

# Cluster defaults
ENGINE=rke2
DEFAULT_OS=ubuntu-24.04
CLUSTER_NODES=3
CLUSTER_VIP=192.0.2.10
CLUSTER_DOMAIN=city-intersection.example.com
KUBECONFIG=/etc/rancher/rke2/rke2.yaml

# Runtime selections
WEB=nginx
DB=postgresql
OBS=elasticsearch

# Git remotes
GITHUB_OWNER=your-github-org-or-user
GITHUB_VISIBILITY=private
GITLAB_URL=https://gitlab.com
GITLAB_NAMESPACE_ID=
GITLAB_VISIBILITY=private
