[Unit]
Description=City Intersection raw service %i
After=network-online.target
Wants=network-online.target

[Service]
User=citysvc
Group=citysvc
WorkingDirectory=/opt/city-intersection/%i
EnvironmentFile=-/etc/city-intersection/%i.env
ExecStart=/opt/city-intersection/%i/%i
Restart=always
RestartSec=5
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
